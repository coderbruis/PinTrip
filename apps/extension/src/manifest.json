{
  "manifest_version": 3,
  "name": "PinTrip XHS Importer",
  "version": "0.1.0",
  "description": "Capture Xiaohongshu note responses for PinTrip.",
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://edith.xiaohongshu.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
